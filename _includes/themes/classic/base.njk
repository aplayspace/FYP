<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Final Year Projects Showcase</title>
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
</head>
<body>
  <header>
    <div class="container header-container">
      <div class="logo-area">
        <a href="{{ '/' | url }}">
          <img src="{{ '/img/ucd-logo.png' | url }}" alt="UCD Logo" class="header-logo">
          <span class="site-title">UCD CS Final Year Projects</span>
        </a>
      </div>
      <nav>
        <a href="{{ '/' | url }}">Home</a>
        <div class="dropdown">
          <button class="dropbtn">Years ▾</button>
          <div class="dropdown-content">
            <a href="{{ '/2026/' | url }}">2026</a>
            <a href="{{ '/2025/' | url }}">2025</a>
          </div>
        </div>
        <a href="{{ '/all-projects/' | url }}">All Projects</a>
      </nav>
    </div>
  </header>

  <main class="container">
    {{ content | safe }}
  </main>

  <footer>
    <div class="container">
      <p>&copy; 2025 University Final Year Projects. Built with Eleventy.</p>
    </div>
  </footer>
</body>
</html>
